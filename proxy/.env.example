# Optional: Turnstile captcha validation
# Leave empty to disable captcha entirely.
TURNSTILE_SECRET=
JWT_SECRET=

# Optional: disable specific proxy endpoints
DISABLE_M3U8=false

# Optional: enable in-memory TS segment caching (default false)
ENABLE_CACHE=false

# Optional: request debug logging
REQ_DEBUG=false

# Optional: route outbound fetches through a residential/datacenter HTTP proxy
# (used for hosted scraping — sources block Railway/cloud IPs without this)
# UPSTREAM_PROXY=http://user:pass@host:port
