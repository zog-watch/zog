# =============================================================================
# Zog (zog.watch) - Root environment example
# Copy this file to .env and fill in the values.
# Railway will auto-inject these as variables on each service.
# =============================================================================

# -----------------------------------------------------------------------------
# Required: TMDB API key for metadata
# Get one at: https://www.themoviedb.org/settings/api
# -----------------------------------------------------------------------------
VITE_TMDB_READ_API_KEY=
TMDB_API_KEY=

# -----------------------------------------------------------------------------
# Required: Backend crypto secret
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
CRYPTO_SECRET=

# -----------------------------------------------------------------------------
# PostgreSQL database
# Railway automatically provides DATABASE_URL when a Postgres service is linked.
# For local development, use the docker-compose Postgres or set manually.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://zog:zog@localhost:5432/zog?schema=public
DB_PROVIDER=postgres
DB_POOL_MAX=30

# -----------------------------------------------------------------------------
# Optional: Trakt.tv integration
# -----------------------------------------------------------------------------
TRAKT_CLIENT_ID=
TRAKT_SECRET_ID=

# -----------------------------------------------------------------------------
# Optional: Captcha (Cloudflare Turnstile) for proxy
# -----------------------------------------------------------------------------
CAPTCHA=false
CAPTCHA_CLIENT_KEY=
TURNSTILE_SECRET=
JWT_SECRET=

# -----------------------------------------------------------------------------
# Public web configuration
# These are injected into web/public/config.js at runtime.
# -----------------------------------------------------------------------------
VITE_APP_DOMAIN=https://zog.watch
VITE_BACKEND_URL=https://zog-backend.up.railway.app
VITE_CORS_PROXY_URL=https://zog-proxy.up.railway.app
VITE_M3U8_PROXY_URL=https://zog-proxy.up.railway.app
VITE_DMCA_EMAIL=dmca@zog.watch
VITE_NORMAL_ROUTER=true
VITE_PWA_ENABLED=true
VITE_HAS_ONBOARDING=true
VITE_ALLOW_AUTOPLAY=false

# -----------------------------------------------------------------------------
# Docs site
# -----------------------------------------------------------------------------
SITE_URL=https://zog.watch
BASE_PATH=/docs

# -----------------------------------------------------------------------------
# Optional: Proxy tuning
# -----------------------------------------------------------------------------
ENABLE_CACHE=false
DISABLE_M3U8=false
REQ_DEBUG=false
