# Vite build-time variables for the Zog web app.
# In production these can also be overridden at runtime via public/config.js.

# Required
VITE_TMDB_READ_API_KEY=

# Public URLs of your deployed services
VITE_APP_DOMAIN=https://zog.watch
VITE_BACKEND_URL=https://zog-backend.up.railway.app
VITE_CORS_PROXY_URL=https://zog-proxy.up.railway.app
VITE_M3U8_PROXY_URL=https://zog-proxy.up.railway.app

# Optional UI config
VITE_DMCA_EMAIL=dmca@zog.watch
VITE_NORMAL_ROUTER=true
VITE_PWA_ENABLED=true
VITE_OPENSEARCH_ENABLED=false
VITE_HAS_ONBOARDING=true
VITE_ALLOW_AUTOPLAY=false

# Optional onboarding links
VITE_ONBOARDING_CHROME_EXTENSION_INSTALL_LINK=
VITE_ONBOARDING_PROXY_INSTALL_LINK=

# Optional content restrictions
VITE_DISALLOWED_IDS=
VITE_CDN_REPLACEMENTS=
